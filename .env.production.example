# ===========================================
# Baspen Photo — Production Environment
# Domain: mytime.kz
# ===========================================

# --- Database ---
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- MinIO (S3 storage) ---
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_USER
MINIO_SECRET_KEY=CHANGE_ME_MINIO_PASSWORD

# --- S3 public URL (how users access photos via nginx) ---
S3_PUBLIC_URL=https://mytime.kz/photos

# --- AWS Rekognition (Face Recognition) ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME

# --- Auth ---
AUTH_SECRET=CHANGE_ME_RANDOM_64_CHARS
NEXTAUTH_URL=https://mytime.kz

# --- App URL ---
NEXT_PUBLIC_APP_URL=https://mytime.kz

# --- Email (Resend) ---
RESEND_API_KEY=re_CHANGE_ME
RESEND_FROM_EMAIL=noreply@mytime.kz
