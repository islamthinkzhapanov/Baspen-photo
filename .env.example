# Baspen Photo — Environment Variables

# Database
DATABASE_URL=postgresql://baspen:CHANGE_ME@localhost:5432/baspen
DB_PASSWORD=CHANGE_ME

# Redis
REDIS_URL=redis://localhost:6379

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=baspen-photos
S3_PUBLIC_URL=http://localhost:9000/baspen-photos
S3_REGION=us-east-1
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Bib Detector
BIB_DETECTOR_URL=http://localhost:8001

# AWS Rekognition (Face Recognition)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
FACE_SIMILARITY_THRESHOLD=80

# Auth
AUTH_SECRET=your-random-auth-secret-here
NEXTAUTH_URL=http://localhost:3000

# Production
# NEXTAUTH_URL=https://baspen.kz
# S3_PUBLIC_URL=https://baspen.kz/photos
