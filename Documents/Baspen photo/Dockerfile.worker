FROM node:22-alpine

# Install pnpm
RUN corepack enable && corepack prepare pnpm@latest --activate

WORKDIR /app

# Dependencies
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
RUN pnpm install --frozen-lockfile

# Source
COPY src ./src
COPY worker ./worker
COPY tsconfig.json ./

ENV NODE_ENV=production

CMD ["pnpm", "worker"]
